# US Visa Bot Configuration
# Copy this file to .env and fill in your actual values

# Your credentials for https://ais.usvisa-info.com/
EMAIL=your.email@example.com
PASSWORD=your_password_here

# Country code - found in the URL (e.g. 'cl' for Chile, 'fr' for France)
COUNTRY_CODE=cl

# Schedule ID - found in the URL when trying to reschedule manually
# URL format: https://ais.usvisa-info.com/en-{COUNTRY_CODE}/niv/schedule/{SCHEDULE_ID}/continue_actions
SCHEDULE_ID=12345678

# Facility ID - required for the 'bot' command (appointment rescheduling)
# Found in network calls when selecting a new date
# Not required for 'payment-watch' command
FACILITY_ID=44

# Refresh delay in seconds between checks for 'bot' command (default: 3)
REFRESH_DELAY=3

# --- Payment Watch Configuration ---

# Delay in seconds between payment page checks (default: 600 = 10 min)
PAYMENT_CHECK_DELAY=600

# Email to receive notifications when slots appear
NOTIFY_EMAIL=your.email@example.com

# SMTP configuration for email notifications (optional — skipped if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your.email@gmail.com
